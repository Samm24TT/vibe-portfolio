---
const learning = [
  {
    topic: 'Python',
    source: 'Scrimba',
    link: 'https://scrimba.com/learn/python',
  },
  {
    topic: 'JS Algorithms',
    source: 'freeCodeCamp',
    link: 'https://www.freecodecamp.org/learn/javascript-algorithms-and-data-structures-v8/',
  },
  {
    topic: 'Fullstack Dev',
    source: 'Online Class',
    link: null,
  },
  {
    topic: 'Vibe Coding',
    source: 'Vibe Code Tours',
    link: 'https://vibecode.tours/',
  },
];
---

<section class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-xs uppercase tracking-[0.3em] text-gray-400 mb-12 fade-in">Currently Learning</h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px bg-gray-200 border border-gray-200 fade-in">
      {learning.map((item) => (
        <div class="bg-white p-6">
          <h3 class="text-lg font-bold text-black mb-1 font-[var(--font-display)]">
            {item.topic}
          </h3>
          {item.link ? (
            <a
              href={item.link}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-gray-400 hover:text-black transition-colors"
            >
              {item.source} →
            </a>
          ) : (
            <span class="text-sm text-gray-400">
              {item.source}
            </span>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
