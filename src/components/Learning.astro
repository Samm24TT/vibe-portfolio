---
const learning = [
  {
    topic: 'Python',
    source: 'Scrimba',
    link: 'https://scrimba.com/learn/python',
  },
  {
    topic: 'JS Algorithms',
    source: 'freeCodeCamp',
    link: 'https://www.freecodecamp.org/learn/javascript-algorithms-and-data-structures-v8/',
  },
  {
    topic: 'Fullstack Dev',
    source: 'Online Class',
    link: null,
  },
  {
    topic: 'Vibe Coding',
    source: 'Vibe Code Tours',
    link: 'https://vibecode.tours/',
  },
];
---

<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold mb-4 fade-in">
      <span class="gradient-text">Currently Learning</span>
    </h2>
    <div class="h-1 w-16 bg-gradient-to-r from-purple-500 to-blue-500 rounded-full mb-10 fade-in"></div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {learning.map((item) => (
        <div class="glass-card p-5 fade-in">
          <h3 class="text-lg font-bold text-[var(--color-text-primary)] mb-1">
            {item.topic}
          </h3>
          {item.link ? (
            <a
              href={item.link}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-[var(--color-text-muted)] hover:text-purple-400 transition-colors"
            >
              {item.source} →
            </a>
          ) : (
            <span class="text-sm text-[var(--color-text-muted)]">
              {item.source}
            </span>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
