---
const skillGroups = [
  {
    category: 'Languages',
    skills: ['JavaScript', 'Python', 'Java'],
  },
  {
    category: 'Frontend',
    skills: ['HTML', 'CSS', 'React', 'Tailwind CSS'],
  },
  {
    category: 'Tools',
    skills: ['Git', 'GitHub', 'VS Code', 'Claude Code', 'WSL'],
  },
];
---

<section id="skills" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-xs uppercase tracking-[0.3em] text-gray-400 mb-12 fade-in">Skills</h2>

    <div class="grid md:grid-cols-3 gap-12">
      {skillGroups.map((group) => (
        <div class="fade-in">
          <h3 class="text-sm font-bold uppercase tracking-widest text-black mb-5 border-b border-black pb-3">
            {group.category}
          </h3>
          <div class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <span class="skill-tag">
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
