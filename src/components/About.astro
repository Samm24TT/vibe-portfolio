---
const facts = [
  { label: 'Location', value: 'Malaysia' },
  { label: 'University', value: 'INTI International University' },
  { label: 'Degree', value: 'BSc Computer Science' },
  { label: 'Languages', value: 'English, Burmese' },
  { label: 'Interests', value: 'Open Source, AI Tools, Music' },
  { label: 'Status', value: 'Open to Internships' },
];
---

<section id="about" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-xs uppercase tracking-[0.3em] text-gray-400 mb-12 fade-in">About</h2>

    <div class="grid md:grid-cols-5 gap-16">
      <!-- Bio -->
      <div class="md:col-span-3 fade-in">
        <p class="text-2xl md:text-3xl font-medium leading-relaxed text-gray-800 mb-6 font-[var(--font-display)]">
          I'm a Computer Science student who learns by building real projects —
          from responsive landing pages to interactive browser games.
        </p>
        <p class="text-gray-500 leading-relaxed">
          Currently focused on web development and open to internship
          opportunities where I can contribute and grow. When I'm not coding,
          I'm exploring open source, experimenting with AI tools, or playing
          music instruments.
        </p>
      </div>

      <!-- Quick facts -->
      <div class="md:col-span-2 fade-in">
        <div class="border-t border-black pt-6 space-y-4">
          {facts.map((fact) => (
            <div class="flex items-start gap-4">
              <span class="text-xs uppercase tracking-widest text-gray-400 w-24 shrink-0 pt-0.5">
                {fact.label}
              </span>
              <span class="text-sm text-gray-700">
                {fact.value}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
