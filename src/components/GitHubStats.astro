---
---

<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold mb-4 fade-in">
      <span class="gradient-text">GitHub Activity</span>
    </h2>
    <div class="h-1 w-16 bg-gradient-to-r from-purple-500 to-blue-500 rounded-full mb-10 fade-in"></div>

    <div class="grid md:grid-cols-2 gap-6">
      <!-- Contribution graph -->
      <div class="glass-card p-6 fade-in overflow-x-auto">
        <h3 class="text-sm font-bold uppercase tracking-widest text-[var(--color-text-muted)] mb-4">
          Contributions
        </h3>
        <div class="flex justify-center">
          <img
            src="https://ghchart.rshah.org/Samm24TT"
            alt="Samuel's GitHub contribution chart"
            class="w-full max-w-[600px] h-auto opacity-80 hover:opacity-100 transition-opacity"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Stats cards -->
      <div class="flex flex-col gap-4" id="github-stats">
        <div class="glass-card p-6 fade-in flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500/20 to-blue-500/20 border border-purple-500/30 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <div>
            <p class="text-sm text-[var(--color-text-muted)]">Public Repos</p>
            <p class="text-2xl font-bold text-[var(--color-text-primary)] stat-value">Loading...</p>
          </div>
        </div>

        <div class="glass-card p-6 fade-in flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500/20 to-cyan-500/20 border border-blue-500/30 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
          </div>
          <div>
            <p class="text-sm text-[var(--color-text-muted)]">Total Stars</p>
            <p class="text-2xl font-bold text-[var(--color-text-primary)] stat-value">Loading...</p>
          </div>
        </div>

        <div class="glass-card p-6 fade-in flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-cyan-500/20 to-green-500/20 border border-cyan-500/30 flex items-center justify-center shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <div>
            <p class="text-sm text-[var(--color-text-muted)]">Followers</p>
            <p class="text-2xl font-bold text-[var(--color-text-primary)] stat-value">Loading...</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  async function fetchGitHubStats() {
    try {
      const res = await fetch('https://api.github.com/users/Samm24TT');
      const data = await res.json();

      const statValues = document.querySelectorAll('#github-stats .stat-value');
      if (statValues.length >= 3) {
        statValues[0].textContent = data.public_repos ?? '—';
        statValues[1].textContent = '—'; // Stars need a separate API call
        statValues[2].textContent = data.followers ?? '—';
      }
    } catch {
      // Silently fail — stats show "Loading..." if API is rate-limited
    }

    // Fetch total stars
    try {
      const res = await fetch('https://api.github.com/users/Samm24TT/repos?per_page=100');
      const repos = await res.json();
      const stars = repos.reduce((sum: number, r: any) => sum + (r.stargazers_count || 0), 0);
      const statValues = document.querySelectorAll('#github-stats .stat-value');
      if (statValues[1]) {
        statValues[1].textContent = String(stars);
      }
    } catch {
      // Silently fail
    }
  }

  fetchGitHubStats();
</script>
