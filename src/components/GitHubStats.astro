---
---

<section class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-xs uppercase tracking-[0.3em] text-gray-400 mb-12 fade-in">GitHub Activity</h2>

    <div class="grid md:grid-cols-2 gap-px bg-gray-200 border border-gray-200 fade-in">
      <!-- Contribution graph -->
      <div class="bg-white p-6">
        <h3 class="text-xs uppercase tracking-widest text-gray-400 mb-4">Contributions</h3>
        <div class="overflow-x-auto">
          <img
            src="https://ghchart.rshah.org/Samm24TT"
            alt="Samuel's GitHub contribution chart"
            class="w-full max-w-[500px] h-auto opacity-70 hover:opacity-100 transition-opacity"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Stats -->
      <div id="github-stats" class="bg-white p-6 flex flex-col justify-center gap-6">
        <div class="flex items-center gap-4">
          <span class="text-4xl font-bold text-black font-[var(--font-display)] stat-value">—</span>
          <span class="text-xs uppercase tracking-widest text-gray-400">Public Repos</span>
        </div>
        <div class="h-px bg-gray-100"></div>
        <div class="flex items-center gap-4">
          <span class="text-4xl font-bold text-black font-[var(--font-display)] stat-value">—</span>
          <span class="text-xs uppercase tracking-widest text-gray-400">Total Stars</span>
        </div>
        <div class="h-px bg-gray-100"></div>
        <div class="flex items-center gap-4">
          <span class="text-4xl font-bold text-black font-[var(--font-display)] stat-value">—</span>
          <span class="text-xs uppercase tracking-widest text-gray-400">Followers</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  async function fetchGitHubStats() {
    try {
      const res = await fetch('https://api.github.com/users/Samm24TT');
      const data = await res.json();

      const statValues = document.querySelectorAll('#github-stats .stat-value');
      if (statValues.length >= 3) {
        statValues[0].textContent = data.public_repos ?? '—';
        statValues[2].textContent = data.followers ?? '—';
      }
    } catch {}

    try {
      const res = await fetch('https://api.github.com/users/Samm24TT/repos?per_page=100');
      const repos = await res.json();
      const stars = repos.reduce((sum: number, r: any) => sum + (r.stargazers_count || 0), 0);
      const statValues = document.querySelectorAll('#github-stats .stat-value');
      if (statValues[1]) {
        statValues[1].textContent = String(stars);
      }
    } catch {}
  }

  fetchGitHubStats();
</script>
