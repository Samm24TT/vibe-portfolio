---
const projects = [
  {
    name: 'BeatStrike',
    tech: ['Vite', 'React', 'Web Audio API'],
    description: 'Browser-based rhythm game with beat detection powered by the Web Audio API. Game state and note timing managed with React hooks.',
    link: 'https://github.com/Samm24TT/Personal-Project',
    image: '/images/beatstrike.svg',
    number: '01',
  },
  {
    name: 'Meet Landing Page',
    tech: ['HTML', 'CSS', 'Responsive Design'],
    description: 'Mobile-first landing page with fluid typography, media queries, semantic HTML, and accessible markup.',
    link: 'https://github.com/Samm24TT/meet-landing-page',
    image: '/images/meet-landing.svg',
    number: '02',
  },
  {
    name: 'Testimonials Grid',
    tech: ['HTML', 'CSS Grid'],
    description: 'Multi-breakpoint CSS Grid layout from mobile to desktop. Uses grid template areas for readable, maintainable code.',
    link: 'https://github.com/Samm24TT/Testimonials-grid-section',
    image: '/images/testimonials.svg',
    number: '03',
  },
  {
    name: 'Product Preview Card',
    tech: ['HTML', 'CSS', 'Responsive Design'],
    description: 'Responsive card component with image swapping at breakpoints and pixel-perfect typography and spacing.',
    link: 'https://github.com/Samm24TT/product-preview-card',
    image: '/images/product-card.svg',
    number: '04',
  },
];
---

<section id="projects" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-xs uppercase tracking-[0.3em] text-gray-400 mb-12 fade-in">Projects</h2>

    <div class="space-y-12">
      {projects.map((project) => (
        <a
          href={project.link}
          target="_blank"
          rel="noopener noreferrer"
          class="group grid md:grid-cols-2 gap-6 fade-in block"
        >
          <!-- Screenshot -->
          <div class="overflow-hidden border border-gray-200 group-hover:border-black transition-colors">
            <img
              src={project.image}
              alt={`${project.name} preview`}
              class="w-full h-48 md:h-56 object-cover object-top grayscale group-hover:grayscale-0 transition-all duration-500"
              loading="lazy"
            />
          </div>

          <!-- Info -->
          <div class="flex flex-col justify-center">
            <span class="text-xs text-gray-400 font-mono mb-2">{project.number}</span>
            <h3 class="text-2xl font-bold text-black mb-3 font-[var(--font-display)] group-hover:translate-x-1 transition-transform">
              {project.name}
            </h3>

            <div class="flex flex-wrap gap-2 mb-4">
              {project.tech.map((t) => (
                <span class="text-xs px-2 py-0.5 border border-gray-200 text-gray-500">
                  {t}
                </span>
              ))}
            </div>

            <p class="text-sm text-gray-500 leading-relaxed">
              {project.description}
            </p>

            <span class="text-xs uppercase tracking-widest text-gray-400 mt-4 group-hover:text-black transition-colors">
              View on GitHub →
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
